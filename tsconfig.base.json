{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,

    /* 🔑 MONOREPO SUPPORT */
    "baseUrl": ".",
    "paths": {
      "@buildez/db": ["packages/db/src"],
      "@buildez/auth": ["packages/auth/src"]
    }
  }
}
